{
  "name": "renumber-tools",
  "displayName": "RENUMBER TOOLS",
  "description": "renumbers tools in NC Programs to match your tool database based on tool description",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "renumber-tools.renumberGCode",
        "title": "Renumber Tools To Master Tool List"
      },
      {
        "command": "renumber-tools.openToolList",
        "title": "Edit Tool List"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "renumber-tools.renumberGCode",
          "group": "modification",
          "when": "editorTextFocus"
        },
        {
          "command": "renumber-tools.openToolList",
          "group": "modification"
        }
      ]
    },
    "configuration": {
      "title": "RENUMBER TOOLS",
      "properties": {
        "renumber-tools.shopToolList": {
          "type": "array",
          "description": "List of shop tool descriptions and their standard numbers.",
          "default": [
            { "description": "2.5\" DIA FACE MILL", "toolNumber": 1 },
            { "description": "2\" DIA FACE MILL WITH OCTAGONAL INSERTS", "toolNumber": 1 },
            { "description": "3/8\" Spot Drill", "toolNumber": 2 },
            { "description": "3/8\" Flat Endmill 4 FLUTE", "toolNumber": 4 },
            { "description": "5/16\" DIA X 45 DEG X 4 FLUTE CHAMFER MILL", "toolNumber": 3 },
            { "description": "3/16\" Flat Endmill", "toolNumber": 8 },
            { "description": "1/8\" dia x 30 deg engraving tool", "toolNumber": 9 },
            { "description": "1/2\" Flat Endmill", "toolNumber": 15 },
            { "description": "1/2\" Flat Endmill 2 IN LOC", "toolNumber": 16 },
            { "description": "1/4\" Flat Endmill ROUGHING", "toolNumber": 17 },
            { "description": "3/8\" Flat EM 3 FLUTE", "toolNumber": 20 },
            { "description": "PROBE", "toolNumber": 24 },
            { "description": "HSHF, 2\" Diameter Shell Mill", "toolNumber": 59 },
            { "description": "1/2 HIGH FEED ENDMILL", "toolNumber": 60 },
            { "description": "1\" INDEXABLE SANDVIK END MILL", "toolNumber": 61 }
          ],
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "toolNumber": { "type": "integer" }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}